{
  "name": "Goald Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined",
    "--device=/dev/kvm:/dev/kvm",
    "--group-add=plugdev"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "expo.vscode-expo-tools",
        "msjsdiag.vscode-react-native",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        "ms-vscode.vscode-typescript-next",
        "formulahendry.auto-rename-tag",
        "christian-kohler.path-intellisense",
        "streetsidesoftware.code-spell-checker",
        "usernamehw.errorlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit",
          "source.organizeImports": "explicit"
        },
        "eslint.validate": [
          "typescript",
          "typescriptreact"
        ],
        "typescript.preferences.importModuleSpecifier": "relative",
        "typescript.updateImportsOnFileMove.enabled": "always",
        "files.exclude": {
          "**/node_modules": true,
          "**/.expo": true,
          "**/.git": false
        },
        "search.exclude": {
          "**/node_modules": true,
          "**/.expo": true,
          "**/*.log": true
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "EXPO_DEVTOOLS_LISTEN_ADDRESS": "0.0.0.0",
          "REACT_NATIVE_PACKAGER_HOSTNAME": "0.0.0.0"
        }
      }
    }
  },
  "forwardPorts": [
    8081,
    8082,
    19000,
    19001,
    19002,
    19006,
    8080,
    5554,
    5555
  ],
  "portsAttributes": {
    "8081": {
      "label": "Expo Dev Server",
      "onAutoForward": "notify"
    },
    "19000": {
      "label": "Expo DevTools",
      "onAutoForward": "notify"
    },
    "19006": {
      "label": "Expo Web",
      "onAutoForward": "notify"
    },
    "5555": {
      "label": "ADB",
      "onAutoForward": "ignore"
    }
  },
  "postCreateCommand": ".devcontainer/postCreateCommand.sh",
  "postStartCommand": "echo '🚀 Goald Dev Container Ready!' && echo 'Run \"make dev\" to start Expo'",
  "postAttachCommand": "echo '📎 Attached to Goald Dev Container'",
  "remoteUser": "node",
  "containerEnv": {
    "NODE_ENV": "development",
    "EXPO_DEVTOOLS_LISTEN_ADDRESS": "0.0.0.0",
    "REACT_NATIVE_PACKAGER_HOSTNAME": "0.0.0.0",
    "WATCHPACK_POLLING": "true",
    "CHOKIDAR_USEPOLLING": "true",
    "ANDROID_SDK_ROOT": "/opt/android-sdk",
    "ANDROID_HOME": "/opt/android-sdk"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/node/.npm-global/bin:/home/node/.opencode/bin:/opt/android-sdk/cmdline-tools/latest/bin:/opt/android-sdk/platform-tools:/opt/android-sdk/emulator"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "enableRootlessDocker": "true"
    }
  },
  "mounts": [
    "source=goald-node-modules,target=/workspaces/Goald/node_modules,type=volume",
    "source=goald-expo-cache,target=/home/node/.expo,type=volume"
  ]
}