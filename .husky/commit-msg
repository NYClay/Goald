#!/usr/bin/env bash
# Enforce conventional commit messages
# Format: type(scope): description
# Types: feat, fix, test, docs, chore, refactor, perf, ci, build, revert

commit_msg=$(cat "$1")

pattern="^(feat|fix|test|docs|chore|refactor|perf|ci|build|revert)(\(.+\))?: .{1,72}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "ERROR: Commit message does not follow conventional format."
  echo ""
  echo "Expected: type(scope): description"
  echo "Types: feat, fix, test, docs, chore, refactor, perf, ci, build, revert"
  echo ""
  echo "Examples:"
  echo "  feat: add bear feeding modal"
  echo "  fix(auth): resolve login timeout"
  echo "  docs: update architecture guide"
  echo ""
  echo "Your message: $commit_msg"
  exit 1
fi
